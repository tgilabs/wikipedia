# Appwrite Configuration
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=labs

# Discord Server/Guild Configuration (for role verification)
DISCORD_GUILD_ID=418801915162263574
DISCORD_REQUIRED_ROLE_ID=507964393300951040

# GitHub Configuration
GITHUB_OWNER=tgilabs
GITHUB_REPO=wikipedia
GITHUB_BRANCH=Production

# CMS Configuration
# Discord OAuth - Get these from: https://discord.com/developers/applications
REACT_APP_DISCORD_CLIENT_ID=your_discord_client_id_here
REACT_APP_DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# GitHub Personal Access Token for CMS
# Create at: https://github.com/settings/tokens
# Required permissions: Contents (R/W), Pull Requests (R/W)
REACT_APP_GITHUB_TOKEN=your_github_personal_access_token_here
